# PostgreSQL connection string for the Asset Manager database
# Create the database first:  psql -c "CREATE DATABASE rea3_assets;"
ASSET_DB_URL="postgresql://postgres:your_password@localhost:5432/rea3_assets?schema=public"

# Internal API key used when calling the core ReA3 ERP for SKU sync
# Must match a key configured in the ERP's ERP_INTERNAL_API_KEYS
ERP_INTERNAL_API_KEY=""

# Base URL of the core ReA3 ERP (default: http://localhost:3000)
ERP_INTERNAL_URL="http://localhost:3000"
